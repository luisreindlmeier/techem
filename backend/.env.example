# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-service-role-key>

# CORS — set to your Vercel frontend URL after first deploy
FRONTEND_ORIGIN=https://<your-app>.vercel.app

# Table config (defaults match schema.sql — only override if changed)
SUPABASE_TABLE=daily_property_metrics
SUPABASE_TIME_COLUMN=reading_date
SUPABASE_ENERGY_COLUMN=total_energy_kwh
SUPABASE_EMISSION_COLUMN=total_emission_kg_co2e
